APP_NAME="Roberto Cordes"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tudominio.com
TRUSTED_PROXIES=

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_LEVEL=warning

# -----------------------------
# DATABASE
# -----------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=robertocordes_db
DB_USERNAME=root
DB_PASSWORD=

# -----------------------------
# SESSION / CACHE / QUEUE
# -----------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=file

QUEUE_CONNECTION=database

# -----------------------------
# SECURITY
# -----------------------------
ADMIN_ALLOWED_EMAILS=
FORM_HONEYPOT_FIELD=company
FORM_RATE_LIMIT_MAX_ATTEMPTS=5
FORM_RATE_LIMIT_DECAY_SECONDS=60
PAGE_MEDIA_IMAGE_MAX_KB=10240
PAGE_MEDIA_VIDEO_MAX_KB=51200

# -----------------------------
# FILESYSTEM
# -----------------------------
FILESYSTEM_DISK=public

# -----------------------------
# MAIL
# (Use 'log' for dev, 'smtp' for production)
# -----------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="contacto@robertocordes.com"
MAIL_FROM_NAME="${APP_NAME}"
QUOTE_REQUEST_TO_EMAIL=
QUOTE_REQUEST_CC_EMAIL=
CATALOG_REQUEST_TO_EMAIL=
CATALOG_REQUEST_CC_EMAIL=
CONTACT_REQUEST_TO_EMAIL=
CONTACT_REQUEST_CC_EMAIL=

# -----------------------------
# REDIS (OPTIONAL)
# -----------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------
# AWS (NOT USED)
# -----------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# -----------------------------
# VITE
# -----------------------------
VITE_APP_NAME="${APP_NAME}"
